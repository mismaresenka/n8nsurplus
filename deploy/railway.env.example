# ============================================================
# n8n on Railway — environment variables
# ============================================================
# Set these on the n8n SERVICE in Railway (Variables → "Raw Editor").
# Do NOT commit real values — this file is an example/template only.
#
# Trim B: the database lives on Supabase Cloud (free tier), OFF the Railway bill.
# Use a DEDICATED Supabase project for n8n (not any other app's project) — the
# DB values below come from that project's Session-pooler connection string.
# ============================================================

# ---- Core + proxy (Railway terminates TLS in front of n8n) ----
N8N_HOST=<your-n8n-subdomain>.up.railway.app
N8N_PROTOCOL=https
N8N_PORT=5678
WEBHOOK_URL=https://<your-n8n-subdomain>.up.railway.app/
N8N_EDITOR_BASE_URL=https://<your-n8n-subdomain>.up.railway.app/
# n8n sits behind Railway's reverse proxy — needed for correct webhook URLs
# and for the secure session cookie to be set properly.
N8N_PROXY_HOPS=1

# ---- Encryption — MUST equal the OLD instance's value (copy from this repo's .env) ----
# If this does not match, every stored credential (OpenRouter, Templated,
# Facebook Page token, Telegram bot token) becomes unreadable.
N8N_ENCRYPTION_KEY=<exact existing value>

# ---- Database = dedicated Supabase Cloud Postgres project (Trim B) ----
# From Supabase → Project Settings → Database → Connection string → SESSION POOLER
# (port 5432, IPv4 — works from Railway). Do NOT use the Transaction pooler on
# 6543 (breaks n8n's prepared statements) or the IPv6-only direct host.
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=aws-0-<region>.pooler.supabase.com
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres.<project-ref>          # pooler user carries the .<ref> suffix
DB_POSTGRESDB_PASSWORD=<supabase database password>
# Supabase requires SSL:
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false        # simplest; tighten later via DB_POSTGRESDB_SSL_CA
# If you SHARE another project's Supabase database instead of a dedicated one,
# isolate n8n's tables with its own schema (and remap public→n8n on restore —
# see RAILWAY-MIGRATION.md):
#   DB_POSTGRESDB_SCHEMA=n8n

# ---- Timezone (the slot-picker scheduler workflow depends on it) ----
GENERIC_TIMEZONE=Asia/Manila
TZ=Asia/Manila

# ---- Execution data retention (carried over from docker-compose.yml) ----
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=last
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336

# ---- Email (OPTIONAL: only needed for user-management invites / password reset) ----
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=<smtp host>
N8N_SMTP_PORT=587
N8N_SMTP_USER=<smtp user>
N8N_SMTP_PASS=<smtp pass>
N8N_SMTP_SENDER=<sender>

# ---- Telemetry off ----
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false

# ---- Removed vs. docker-compose.yml ----
# N8N_BASIC_AUTH_ACTIVE / _USER / _PASSWORD — basic auth is deprecated/removed in
# n8n 1.x+. Login now uses the built-in owner account, which travels with the DB
# migration (or is created on first visit for a fresh DB).
