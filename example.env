# ============================================================
# A&A n8n — Environment Variables
# ============================================================
# 1. Rename this file to  .env  (remove the .example suffix)
# 2. Fill in every value below — DO NOT leave placeholders
# 3. Keep this file out of Git: add .env to your .gitignore
# ============================================================

# ---- n8n host & URL ----------------------------------------
# The domain/IP your n8n instance is reachable at.
# If running locally only (no domain), use:
#   N8N_HOST=localhost
#   N8N_PROTOCOL=http
#   WEBHOOK_URL=http://localhost:5678/
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# ---- n8n login credentials ---------------------------------
# Username and password for the n8n web UI.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# ---- Encryption key ----------------------------------------
# Protects all credentials stored inside n8n (API keys, tokens).
# Generate with:  openssl rand -hex 32
# WARNING: if you change this after setup, stored credentials
# will be unreadable and must be re-entered.
N8N_ENCRYPTION_KEY=

# ---- Postgres database -------------------------------------
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=change-me-to-something-strong

# ---- SMTP (for n8n error emails) ---------------------------
# Optional but recommended. Use Gmail App Password or any SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SENDER=your-email@gmail.com

# ============================================================
# API KEYS — store these in n8n's Credentials UI, NOT here.
# Listed below as a reminder of what you'll need to add
# inside n8n after first login:
#
#   - Claude API key         (Anthropic console)
#   - Notion integration token
#   - Canva API credentials
#   - Buffer API token
#   - Facebook Graph API token (Phase 2)
#   - WhatsApp / Gmail node credentials
# ============================================================

# cloudflared tunnel --url http://localhost:5678 