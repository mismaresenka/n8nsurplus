# NEVER commit secrets
.env

*.key
*.pem

# DB dumps (contain encrypted credentials, e.g. the migration backup) — never commit
*.sql

# Podman/Docker runtime files
.podman/
.docker/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor folders
.vscode/
.idea/

# Node (if you add any local scripts later)
node_modules/

# ============================================================
# WHAT DOES GET COMMITTED:
#   docker-compose.yml   — infra definition
#   .env.example         — template (no real values)
#   workflows/*.json     — exported n8n workflows ✓
#   GIT_SETUP.sh         — this setup guide
#   .gitignore           — this file
# ============================================================